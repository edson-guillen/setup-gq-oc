# =============================================================
# setup-gq-oc — Variáveis de Ambiente
# Gerado automaticamente por install.sh / first-run.sh
# =============================================================

# Ativa modo OpenAI-compatível no OpenClaude
export CLAUDE_CODE_USE_OPENAI=1

# Proxy local do gqwen-auth
export OPENAI_BASE_URL=http://localhost:3099/v1

# Qualquer valor — o proxy ignora, mas a lib exige campo preenchido
export OPENAI_API_KEY=gqwen-proxy

# Modelo padrão (opções: qwen3-coder-plus | qwen3-coder-flash | vision-model | coder-model)
export OPENAI_MODEL=qwen3-coder-plus

# Retentativas em rate limit (padrão: 10)
# export CLAUDE_CODE_MAX_RETRIES=10

# Modo CI/unattended: retenta 429/529 indefinidamente
# export CLAUDE_CODE_UNATTENDED_RETRY=1
